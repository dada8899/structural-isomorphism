# Legacy v3 expanded knowledge base
v3/results/kb-expanded-struct.jsonl filter=lfs diff=lfs merge=lfs -text

# Top-level knowledge-base aggregates (>1MB)
data/kb-5000-merged.jsonl filter=lfs diff=lfs merge=lfs -text
data/kb-expanded.jsonl filter=lfs diff=lfs merge=lfs -text
data/clean-expanded.jsonl filter=lfs diff=lfs merge=lfs -text

# === Explicit exclusions from LFS ===
# Small config/output jsonl under v4/results/ stay in regular git
# (<100KB analyses/summaries — LFS pointer overhead not worth it)
v4/results/*.jsonl !filter !diff !merge
v4/results/*.json !filter !diff !merge
