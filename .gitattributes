v4/validation/soc-defi/maker_dog_liquidations.jsonl filter=lfs diff=lfs merge=lfs -text
v4/validation/soc-neural/neural_avalanches.jsonl filter=lfs diff=lfs merge=lfs -text
v4/validation/soc-neural/synthetic_avalanches.jsonl filter=lfs diff=lfs merge=lfs -text
v4/validation/soc-neural/bf_1.jsonl filter=lfs diff=lfs merge=lfs -text
v4/validation/soc-neural/bf_2.jsonl filter=lfs diff=lfs merge=lfs -text
v4/validation/soc-solar/flares.jsonl filter=lfs diff=lfs merge=lfs -text
v4/validation/soc-wildfire/fires.jsonl filter=lfs diff=lfs merge=lfs -text
v4/validation/soc-github-stars/repos.jsonl filter=lfs diff=lfs merge=lfs -text
v4/validation/soc-bank-failures/raw_fdic.json filter=lfs diff=lfs merge=lfs -text
