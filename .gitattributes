# Future validation raw data — any csv under raw/ subdirs goes LFS
v4/validation/**/raw/*.csv filter=lfs diff=lfs merge=lfs -text
v4/validation/**/raw/*.jsonl filter=lfs diff=lfs merge=lfs -text
v4/validation/**/raw/*.parquet filter=lfs diff=lfs merge=lfs -text

# Web app knowledge-base embeddings (currently >13MB each)
web/data/kb_embeddings.npy filter=lfs diff=lfs merge=lfs -text
web/data/kb_v2_embeddings.npy filter=lfs diff=lfs merge=lfs -text

# Top-level results bundles (screened candidate sets, expanded discoveries — >1MB)
results/exp-screened-all.jsonl filter=lfs diff=lfs merge=lfs -text
results/v2-discoveries-expanded-top5000.jsonl filter=lfs diff=lfs merge=lfs -text
results/v2-discoveries-v2model.jsonl filter=lfs diff=lfs merge=lfs -text
results/v2-discoveries.jsonl filter=lfs diff=lfs merge=lfs -text
results/exp-high-potential.jsonl filter=lfs diff=lfs merge=lfs -text
