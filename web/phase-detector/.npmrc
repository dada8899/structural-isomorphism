# Storybook 8 + @storybook/nextjs require Next.js internals (webpack, babel,
# postcss-loader, css-loader, style-loader, etc) to be hoisted to the project
# root so the framework can resolve them. Without these patterns pnpm's strict
# resolution breaks @storybook/nextjs at build time.
public-hoist-pattern[]=*@storybook/*
public-hoist-pattern[]=*next*
public-hoist-pattern[]=*webpack*
public-hoist-pattern[]=*postcss*
public-hoist-pattern[]=*css-loader*
public-hoist-pattern[]=*style-loader*
public-hoist-pattern[]=*babel*
shamefully-hoist=true
