OPENROUTER_API_KEY=sk-or-v1-xxx
LLM_MODEL=anthropic/claude-sonnet-4.6
STRUCTURAL_DATA_DIR=/path/to/structural-isomorphism/data
STRUCTURAL_KB_FILE=kb-5000-merged.jsonl
STRUCTURAL_MODEL_PATH=/path/to/structural-isomorphism/models/structural-v1
PORT=5004

# W15-B (session #11): JWT signing secret for magic-link auth.
# Generate a fresh random secret on every deploy:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# Server refuses to start if unset in production.
JWT_SECRET=replace-with-48-byte-random-secret

# CORS allow-list (comma-separated). Use exact origins in production.
# Empty / "*" is REJECTED in production for safety.
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://phase.bytedance.city
