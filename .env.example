# Example environment configuration for structural-isomorphism.
#
# Copy this file to `.env` and fill in real values. `.env` is gitignored
# (see .gitignore) — never commit your real keys.
#
# Usage:
#     cp .env.example .env
#     # edit .env, fill in real keys
#     set -a; source .env; set +a
#     python v4/scripts/b3_ensemble.py ...
#
# Or use a process manager like `direnv` / `dotenv-cli` to auto-load.

# ----------------------------------------------------------------------------
# LLM provider keys
# ----------------------------------------------------------------------------

# DeepSeek direct API (used by v4/scripts/b3_ensemble.py and
# v4/product/d1_phase_detector/extract_structtuple.py).
# Get a key at https://platform.deepseek.com.
DEEPSEEK_API_KEY=sk-your-key-here

# OpenRouter (optional fallback router for cross-vendor ensemble; CN region
# may be blocked — see paper appendix).
# OPENROUTER_API_KEY=sk-or-your-key-here

# ----------------------------------------------------------------------------
# Optional configuration
# ----------------------------------------------------------------------------

# Override DeepSeek default model (v4/scripts/b3_ensemble.py respects this).
# DEEPSEEK_MODEL=deepseek-v4-pro

# Override DeepSeek base URL (for self-hosted proxies / region failover).
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1/chat/completions
